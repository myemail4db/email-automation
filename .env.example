# =========================
# Configurations
# =========================

# Email account used to send job batches
SENDER_EMAIL=sender.email@gmail.com

# Recipient email used to send to (where job batches are sent)
RECIPIENT_EMAIL=recipient.email@gmail.com

# Gmail labels
#
# The application automatically builds child labels under the source label.
# Leave blank to use defaults.
#
# Defaults:
#   GMAIL_LABEL_SOURCE=for_friend
#   GMAIL_LABEL_PROCESSED_REVIEW=processed_review
#   GMAIL_LABEL_ERROR=error
#
# Full Gmail labels created by the app:
#   for_friend
#   for_friend/processed_review
#   for_friend/error
GMAIL_LABEL_SOURCE=
GMAIL_LABEL_PROCESSED_REVIEW=
GMAIL_LABEL_ERROR=

# =========================
# Gmail Settings
# =========================

# Path to OAuth credentials file (downloaded from Google Cloud Console)
GOOGLE_CREDENTIALS_FILE=credentials.json

# Path to generated OAuth token file (created after first login)
GOOGLE_TOKEN_FILE=token.json

# =========================
# General Settings
# =========================

# Local directories for file management
# Leave blank to use defaults.
#
# Defaults:
#   LOCAL_PROCESSED_REVIEW_DIR=processed_review
#   LOCAL_READY_TO_SEND_DIR=ready_to_send
#   LOCAL_SENT_ARCHIVE_DIR=sent_archive
#   LOCAL_ERROR_DIR=error
#
# Note:
#   logs/ is fixed automatically by the application and should not be customized.
LOCAL_PROCESSED_REVIEW_DIR=
LOCAL_READY_TO_SEND_DIR=
LOCAL_SENT_ARCHIVE_DIR=
LOCAL_ERROR_DIR=

# Filename prefixes and limits
FALLBACK_PREFIX=job_email
ZIP_PREFIX=job_batch
MAX_FILENAME_LENGTH=100

# Whether to stop the export batch on the first error
CONTINUE_ON_ERROR=True

# Whether to skip manual review and go directly to sending
SKIP_MANUAL_REVIEW=False

# Email body text
# Use \n for new lines. The application converts them to real line breaks.
# Leave blank to use the default.
SEND_BODY_TEXT=

# Signature name shown at the bottom of the batch email
# Leave blank to use the default.
SEND_SIGNATURE_NAME=

# Timezone used for displayed timestamps
DISPLAY_TIMEZONE=America/Los_Angeles
# DISPLAY_TIMEZONE=America/New_York
# DISPLAY_TIMEZONE=Europe/London
# DISPLAY_TIMEZONE=Asia/Tokyo

# Safety settings
# Recommended first run:
#   SEND_EMAILS=False
#   TEST_MODE=True
# Recommended production:
#   SEND_EMAILS=True
#   TEST_MODE=False
SEND_EMAILS=False
TEST_MODE=True

# =========================
# Logging settings
# =========================
LOG_LEVEL=INFO
LOG_FILE=email_automation.log
LOG_MAX_BYTES=1048576
LOG_BACKUP_COUNT=10
LOG_ENABLE_CONSOLE=True

# Retention values are validated and available for future cleanup policies.
LOG_RETENTION_ENABLED=True
LOG_RETENTION_MAX_BATCHES=100
LOG_RETENTION_MAX_DAYS=30
