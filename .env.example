# =========================
# Email Automation Settings
# =========================

# Email account used to send job batches
SENDER_EMAIL=your_email@example.com

# Recipient email (where job batches are sent)
RECIPIENT_EMAIL=recipient@example.com

# =========================
# Gmail Settings (if using Gmail)
# =========================

# Path to OAuth credentials file (downloaded from Google Cloud Console)
GOOGLE_CREDENTIALS_FILE=credentials.json

# Path to generated OAuth token file (created after first login)
GOOGLE_TOKEN_FILE=token.json

# =========================
# SMTP Settings (Optional - if not using OAuth)
# =========================

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_app_password_here

# =========================
# General Settings
# =========================

# Enable or disable sending emails (True/False)
SEND_EMAILS=False

# Enable test mode (True/False)
TEST_MODE=True